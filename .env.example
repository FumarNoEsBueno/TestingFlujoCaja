# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE AMBIENTES — TestingFlujoCaja
# ═══════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env y completa con las credenciales reales.
# NUNCA hagas commit del archivo .env con credenciales reales.
# ═══════════════════════════════════════════════════════════════════════════

# ─── URLs de los ambientes ──────────────────────────────────────────────────
# Cambiar estas URLs según el ambiente que quieras probar

# Desarrollo local (default)
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:8000

# Staging (descomenta y comenta las de arriba para cambiar de ambiente)
# FRONTEND_URL=https://staging.flujocaja.cl
# BACKEND_URL=https://staging-api.flujocaja.cl

# Producción (descomenta y comenta las de arriba para cambiar de ambiente)
# FRONTEND_URL=https://flujocaja.cl
# BACKEND_URL=https://api.flujocaja.cl

# ─── Credenciales de usuario para testing ──────────────────────────────────
# IMPORTANTE: Estos usuarios deben existir en el ambiente target

# Usuario administrador (acceso completo)
ADMIN_USER_RUT=12345678
ADMIN_USER_DV=9
ADMIN_USER_PASSWORD=Password123!

# Usuario estándar (acceso limitado)
USER_USER_RUT=87654321
USER_USER_DV=5
USER_USER_PASSWORD=Password123!

# ─── Configuración de timeouts (ms) ────────────────────────────────────────
DEFAULT_TIMEOUT=30000
ASYNC_OPERATION_TIMEOUT=10000

# ─── Configuración de reportería ───────────────────────────────────────────
# 'on' = siempre, 'off' = nunca, 'retain-on-failure' = solo si falla
VIDEO_RECORDING=retain-on-failure
TRACE_COLLECTION=on-first-retry

# ─── Configuración de base de datos (para queries directas si es necesario) ─
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=flujocaja_test
# DB_USERNAME=root
# DB_PASSWORD=
